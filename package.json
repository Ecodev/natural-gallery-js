{
    "name": "@ecodev/natural-gallery-js",
    "description": "A lazy load, infinite scroll, natural and masonry layout gallery",
    "author": "Samuel Baptista <samuel.baptista@ecodev.ch>",
    "license": "MIT",
    "version": "11.1.3-7-g52ad7dc",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ecodev/natural-gallery-js.git"
    },
    "bugs": {
        "url": "https://github.com/Ecodev/natural-gallery-js/issues"
    },
    "homepage": "https://github.com/Ecodev/natural-gallery-js#readme",
    "type": "module",
    "exports": {
        ".": "./natural-gallery.js",
        "./natural-gallery.css": "./natural-gallery.css"
    },
    "typings": "./natural-gallery.d.ts",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev": "concurrently --kill-others \"tsdown --watch src/\" \"cross-env DOCS=1 tsdown --watch src/\" \"pnpm run dev-docs\"",
        "dev-docs": "cd docs && bundle install && bundle exec jekyll serve --livereload",
        "build": "tsdown && cross-env DOCS=1 tsdown && cd dist && pnpm version --no-git-checks --no-git-tag-version --allow-same-version `git describe --tags --always`",
        "unit": "vitest run --coverage",
        "e2e": "playwright test",
        "test": "pnpm unit && pnpm e2e",
        "lint-fix": "eslint . --fix",
        "lint": "eslint .",
        "prettier": "./node_modules/.bin/prettier --write .",
        "relink": "cd dist && (pnpm unlink ; pnpm link)"
    },
    "keywords": [
        "gallery",
        "image",
        "images",
        "slideshow",
        "lightbox",
        "zoom",
        "list",
        "autoload",
        "lazyload",
        "infinite",
        "scroll",
        "infinite scroll"
    ],
    "packageManager": "pnpm@11.2.1",
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.54.1",
        "@tsdown/css": "^0.21.10",
        "@typescript-eslint/eslint-plugin": "^8.36.0",
        "@typescript-eslint/parser": "^8.36.0",
        "@vitest/coverage-v8": "^4.1.5",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "domino": "^2.1.6",
        "es-toolkit": "^1.39.7",
        "eslint": "^10.3.0",
        "eslint-plugin-jsdoc": "^62.9.0",
        "globals": "^17.6.0",
        "jsdom": "^29.1.1",
        "photoswipe": "^5.4.4",
        "prettier": "^3.6.2",
        "sass": "^1.99.0",
        "tsdown": "^0.21.10",
        "typescript": "~6.0.3",
        "vitest": "^4.1.5"
    }
}
